n class="o">-&lt;/span>&lt;span class="n">bit&lt;/span> &lt;span class="n">images&lt;/span>&lt;span class="p">,&lt;/span> &lt;span class="k">this&lt;/span> &lt;span class="n">means&lt;/span> &lt;span class="n">Qt&lt;/span>&lt;span class="o">::&lt;/span>&lt;span class="n">color0&lt;/span>&lt;span class="p">.&lt;/span>
